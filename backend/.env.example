# =============================================
# Hotel Backend - Environment Variables
# =============================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database
DB_NAME=hostel_db
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# Azure Database for PostgreSQL (production — overrides DB_* vars)
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Azure Blob Storage (images for rooms & cleaning)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=media

# Sentry error tracking (production)
# SENTRY_DSN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# =============================================
# Cleaning AI Verification (Google Gemini)
# =============================================
# Free-tier Gemini judges room-cleaning photos. Leave the key blank in CI/dev:
# the analyser then FAILS CLOSED (rejects) so a missing/disabled AI can never
# silently auto-approve a dirty room.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Defaults to true when a key is present; set explicitly to force on/off.
# GEMINI_ENABLED=False
GEMINI_TIMEOUT_SECONDS=30

# Safety: never auto-approve on AI error/timeout/quota/parse failure.
CLEANING_AI_FAIL_CLOSED=True
# Dev-only deterministic stub (approves when all 4 zone photos present). Keep
# OFF in production; tests mock the analyser directly.
CLEANING_AI_DEV_STUB=False

# Image hygiene + retention.
CLEANING_IMAGE_MAX_EDGE=1600
CLEANING_IMAGE_JPEG_QUALITY=75
CLEANING_IMAGE_RETENTION_DAYS=30

# Perceptual-hash duplicate detection (Hamming threshold + look-back window).
CLEANING_PHASH_MAX_DISTANCE=5
CLEANING_PHASH_WINDOW_DAYS=30
