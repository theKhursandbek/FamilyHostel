# ==============================================================================
# Hotel — Docker environment variables
# Copy to .env.docker and fill in real values before running docker-compose.
# ==============================================================================

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# PostgreSQL (must match docker-compose postgres service)
DB_NAME=hostel_db
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=postgres
DB_PORT=5432

# Azure Database for PostgreSQL (optional — overrides DB_* vars above)
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
# DB_SSL_REQUIRE=True

# Redis (internal Docker service URLs — no need to change)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_URL=redis://redis:6379/1

# Gunicorn workers (default: 4)
GUNICORN_WORKERS=4

# ──────────────────────────────────────────────────────────────────────────
# Frontend build args (baked into static bundles at docker-compose build)
# ──────────────────────────────────────────────────────────────────────────

# API URL as seen by the browser (use relative path if same domain)
VITE_API_URL=/api/v1
# WebSocket URL (leave blank if same domain — JS will auto-detect)
VITE_WS_URL=

# ──────────────────────────────────────────────────────────────────────────
# Stripe (payments)
# ──────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Telegram Bot
# ──────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_PROD=
TELEGRAM_BOT_TOKEN_STAGING=
TELEGRAM_BOT_ENV=prod
# URL the bot sends users to open the Mini App
TELEGRAM_MINI_APP_URL=https://your-domain.com/app/

# ──────────────────────────────────────────────────────────────────────────
# SMS / OTP (Eskiz.uz gateway for Uzbekistan)
# ──────────────────────────────────────────────────────────────────────────
SMS_BACKEND=apps.common.sms.EskizSmsBackend
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# ──────────────────────────────────────────────────────────────────────────
# Cleaning AI Verification (Google Gemini)
# ──────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=True

# ──────────────────────────────────────────────────────────────────────────
# Chat AI Assistant (OpenAI)
# ──────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────────────────────
# Azure Blob Storage (media files — optional, falls back to local filesystem)
# ──────────────────────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=media

# ──────────────────────────────────────────────────────────────────────────
# Sentry error tracking (optional)
# ──────────────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production

# ──────────────────────────────────────────────────────────────────────────
# Backup system (default: local filesystem)
# ──────────────────────────────────────────────────────────────────────────
BACKUP_STORAGE_BACKEND=local
# BACKUP_AZURE_ACCOUNT_NAME=
# BACKUP_AZURE_ACCOUNT_KEY=
# BACKUP_AZURE_CONTAINER=backups

# ──────────────────────────────────────────────────────────────────────────
# CORS / CSRF — comma-separated origins (include your frontend domain)
# ──────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# SSL — set to True when behind a reverse proxy with TLS termination
SECURE_SSL_REDIRECT=False
