# API base URL (Django REST backend, /api/v1)
VITE_API_URL=http://localhost:8000/api/v1

# Optional: enables a "Sign in with phone" demo button when running outside
# Telegram, so you can test the staff/client experience without a real bot.
# Leave blank in production.
VITE_DEV_FALLBACK_LOGIN=true

# Optional: Sentry DSN for client-side error tracking. Leave blank to disable.
VITE_SENTRY_DSN=
VITE_ENV=development
VITE_APP_VERSION=hotel-mini-app@1.0.0

