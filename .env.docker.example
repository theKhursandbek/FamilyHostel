# ==============================================================================
# FamilyHostel — Docker environment variables
# Copy to .env.docker and fill in real values before running docker-compose.
# ==============================================================================

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (must match docker-compose postgres service)
DB_NAME=hostel_db
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=postgres
DB_PORT=5432

# Redis (internal Docker service URLs — no need to change)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_URL=redis://redis:6379/1

# Gunicorn workers (default: 4)
GUNICORN_WORKERS=4

# Stripe (payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# CORS / CSRF — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# SSL — set to True only when behind a reverse proxy with TLS termination
SECURE_SSL_REDIRECT=False
